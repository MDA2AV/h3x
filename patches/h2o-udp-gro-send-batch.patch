                             size_t num_datagrams, uint8_t ecn)
 {
+#ifdef __linux__
+    if (ctx->batch_sends) {
+        h2o_quic_socket_t *bsock;
+        if (ctx->sock.addr.ss_family == dest->sa.sa_family)
+            bsock = &ctx->sock;
+        else if (ctx->sock_alt_family.sock != NULL && ctx->sock_alt_family.addr.ss_family == dest->sa.sa_family)
+            bsock = &ctx->sock_alt_family;
+        else
+            return 0;
+        return quic_send_batch_add(ctx, bsock, dest, src, datagrams, num_datagrams, ecn);
+    }
+#endif
