+#ifdef __linux__
+/* ---- cross-connection send batching ----
+ * With many connections per worker, sending each connection's datagrams via its own sendmsg is a syscall per
+ * connection per event-loop pass. Instead, when ctx->batch_sends is set we copy each connection's datagrams into a
+ * thread-local buffer with a per-message src-addr/ECN cmsg, and flush them all with one sendmmsg. The worker must
+ * call h2o_quic_flush_datagrams() after each event-loop pass (and we also flush when the buffer fills). */
+#define QUIC_SEND_BATCH 64
+#define QUIC_SEND_DGRAM_MAX 1500
+static __thread struct {
+    int fd; /* fd the queued datagrams go out on; -1 when empty */
+    size_t n;
+    size_t off; /* bytes used in payload */
+    uint8_t payload[QUIC_SEND_BATCH * QUIC_SEND_DGRAM_MAX];
+    struct iovec iovs[QUIC_SEND_BATCH];
+    quicly_address_t dests[QUIC_SEND_BATCH];
+    struct mmsghdr msgs[QUIC_SEND_BATCH];
+    struct {
+        struct cmsghdr _align;
+        char buf[
+#ifdef IPV6_PKTINFO
+            CMSG_SPACE(sizeof(struct in6_pktinfo))
+#elif defined(IP_PKTINFO)
+            CMSG_SPACE(sizeof(struct in_pktinfo))
+#else
+            CMSG_SPACE(1)
+#endif
+            + CMSG_SPACE(sizeof(int)) /* ECN */
+        ];
+    } ctrl[QUIC_SEND_BATCH];
+} send_batch = {.fd = -1};
+
+static void quic_send_batch_flush(h2o_quic_ctx_t *ctx)
+{
+    size_t sent = 0;
+    while (sent < send_batch.n) {
+        int r = sendmmsg(send_batch.fd, send_batch.msgs + sent, (unsigned)(send_batch.n - sent), 0);
+        if (r < 0) {
+            if (errno == EINTR)
+                continue;
+            h2o_error_reporter_record_error(ctx->loop, &track_sendmsg, 60000, errno);
+            break; /* drop the rest; QUIC retransmits */
+        }
+        sent += (size_t)r;
+    }
+    if (sent != 0)
+        h2o_error_reporter_record_success(&track_sendmsg);
+    send_batch.n = 0;
+    send_batch.off = 0;
+    send_batch.fd = -1;
+}
+
+void h2o_quic_flush_datagrams(h2o_quic_ctx_t *ctx)
+{
+    if (send_batch.n != 0)
+        quic_send_batch_flush(ctx);
+}
+
+static int quic_send_batch_add(h2o_quic_ctx_t *ctx, h2o_quic_socket_t *sock, quicly_address_t *dest, quicly_address_t *src,
+                               struct iovec *datagrams, size_t num_datagrams, uint8_t ecn)
+{
+    int fd = h2o_socket_get_fd(sock->sock);
+    for (size_t i = 0; i < num_datagrams; ++i) {
+        if (send_batch.n == QUIC_SEND_BATCH || send_batch.off + datagrams[i].iov_len > sizeof(send_batch.payload) ||
+            (send_batch.n != 0 && send_batch.fd != fd))
+            quic_send_batch_flush(ctx);
+        send_batch.fd = fd;
+        size_t idx = send_batch.n;
+        uint8_t *p = send_batch.payload + send_batch.off; /* copy: quicly reuses its stack buffer after we return */
+        memcpy(p, datagrams[i].iov_base, datagrams[i].iov_len);
+        send_batch.off += datagrams[i].iov_len;
+        send_batch.iovs[idx] = (struct iovec){.iov_base = p, .iov_len = datagrams[i].iov_len};
+        send_batch.dests[idx] = *dest;
+        struct msghdr *mh = &send_batch.msgs[idx].msg_hdr;
+        *mh = (struct msghdr){.msg_name = &send_batch.dests[idx].sa,
+                              .msg_namelen = quicly_get_socklen(&send_batch.dests[idx].sa),
+                              .msg_iov = &send_batch.iovs[idx],
+                              .msg_iovlen = 1,
+                              .msg_control = send_batch.ctrl[idx].buf,
+                              .msg_controllen = sizeof(send_batch.ctrl[idx].buf)};
+        memset(send_batch.ctrl[idx].buf, 0, sizeof(send_batch.ctrl[idx].buf));
+        struct cmsghdr *cmsg = CMSG_FIRSTHDR(mh);
+        if (src->sa.sa_family == AF_INET) {
+#if defined(IP_PKTINFO)
+            struct in_pktinfo info = {.ipi_spec_dst = src->sin.sin_addr};
+            cmsg->cmsg_level = IPPROTO_IP;
+            cmsg->cmsg_type = IP_PKTINFO;
+            cmsg->cmsg_len = CMSG_LEN(sizeof(info));
+            memcpy(CMSG_DATA(cmsg), &info, sizeof(info));
+            cmsg = CMSG_NXTHDR(mh, cmsg);
+#endif
+        } else if (src->sa.sa_family == AF_INET6) {
+#ifdef IPV6_PKTINFO
+            struct in6_pktinfo info = {.ipi6_addr = src->sin6.sin6_addr};
+            cmsg->cmsg_level = IPPROTO_IPV6;
+            cmsg->cmsg_type = IPV6_PKTINFO;
+            cmsg->cmsg_len = CMSG_LEN(sizeof(info));
+            memcpy(CMSG_DATA(cmsg), &info, sizeof(info));
+            cmsg = CMSG_NXTHDR(mh, cmsg);
+#endif
+        }
+        if (ecn != 0) {
+            int tos = ecn;
+            if (dest->sa.sa_family == AF_INET) {
+                cmsg->cmsg_level = IPPROTO_IP;
+                cmsg->cmsg_type = IP_TOS;
+                cmsg->cmsg_len = CMSG_LEN(sizeof(tos));
+                memcpy(CMSG_DATA(cmsg), &tos, sizeof(tos));
+                cmsg = CMSG_NXTHDR(mh, cmsg);
+#ifdef IPV6_TCLASS
+            } else if (dest->sa.sa_family == AF_INET6) {
+                cmsg->cmsg_level = IPPROTO_IPV6;
+                cmsg->cmsg_type = IPV6_TCLASS;
+                cmsg->cmsg_len = CMSG_LEN(sizeof(tos));
+                memcpy(CMSG_DATA(cmsg), &tos, sizeof(tos));
+                cmsg = CMSG_NXTHDR(mh, cmsg);
+#endif
+            }
+        }
+        mh->msg_controllen = (socklen_t)((char *)cmsg - send_batch.ctrl[idx].buf);
+        if (mh->msg_controllen == 0)
+            mh->msg_control = NULL;
+        ++send_batch.n;
+    }
+    return 1;
+}
+#endif
